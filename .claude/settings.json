{
  "permissions": {
    "deny": [
      "Read(.env*)",
      "Read(credentials*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.p12)",
      "Read(.aws/**)",
      "Read(.kube/**)",
      "Read(secrets/**)",
      "Read(.ssh/**)",
      "Read(.docker/config.json)",
      "Write(.env*)",
      "Write(credentials*)",
      "Write(*.pem)",
      "Write(*.key)",
      "Write(*.p12)",
      "Write(.aws/**)",
      "Write(.kube/**)",
      "Write(secrets/**)",
      "Write(.ssh/**)",
      "Write(.docker/config.json)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "denyRead": [
        ".env*",
        "credentials*",
        "*.pem",
        "*.key",
        "*.p12",
        ".aws/**",
        ".kube/**",
        "secrets/**",
        ".ssh/**",
        ".docker/config.json"
      ],
      "denyWrite": [
        ".env*",
        "credentials*",
        "*.pem",
        "*.key",
        "*.p12",
        ".aws/**",
        ".kube/**",
        "secrets/**",
        ".ssh/**",
        ".docker/config.json"
      ]
    }
  }
}
