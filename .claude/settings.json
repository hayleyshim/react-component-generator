{
  "permissions": {
    "blocklist": {
      "description": "민감 파일 접근 차단 (프로젝트 레벨)",
      "files": [
        ".env",
        ".env.local",
        ".env.*.local",
        ".env.production",
        ".env.development",
        "credentials*",
        "*.pem",
        "*.key",
        "*.p12",
        "*.pfx",
        ".aws/**",
        ".ssh/**",
        "secrets/**",
        ".kube/**",
        ".docker/config.json",
        "node_modules/.env*"
      ],
      "operations": ["read", "write"],
      "reason": "API 키, 비밀번호, 개인키 등 민감 정보 보호",
      "message": "🔒 민감 파일 접근 거부\n\n접근 시도한 파일:\n  - 환경변수: .env*\n  - 인증서: *.pem, *.key\n  - 클라우드: .aws/*, .kube/**\n  - 기타: credentials*, secrets/**\n\n필요시 .claude/SECURITY.md를 참고하세요."
    }
  }
}
